// part: metadata

[setup]
drop = "TEST_FLOAT64"

// part: setup_query

CREATE TABLE test_float64 (
    idx INTEGER,
    res DOUBLE PRECISION
);

INSERT INTO test_float64 (idx, res) VALUES (1, 3.14159265358979);
INSERT INTO test_float64 (idx, res) VALUES (2, 0.0);
INSERT INTO test_float64 (idx, res) VALUES (3, -1.0e+300);
INSERT INTO test_float64 (idx, res) VALUES (4, 1.0e+300);
INSERT INTO test_float64 (idx, res) VALUES (5, 2.2250738585072014e-308);
INSERT INTO test_float64 (idx, res) VALUES (6, NULL);

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "RES",
            "format": "g",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"RES": 3.14159265358979}
{"RES": 0.0}
{"RES": -1.0e300}
{"RES": 1.0e300}
{"RES": 2.2250738585072014e-308}
{"RES": null}
